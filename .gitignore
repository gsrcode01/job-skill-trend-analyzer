# Virtual environment folder
# Stores installed packages locally
.venv/
venv/

# Python cache files
# Automatically generated by Python
__pycache__/
*.pyc
*.pyo
*.pyd

# VS Code workspace settings
.vscode/

# macOS hidden system files
.DS_Store

# Streamlit temporary files
.streamlit/

# Generated graphs and charts
# These files are recreated every time the project runs
output/*.png

# Processed datasets generated during analysis
# Original datasets will still be uploaded to GitHub
data/cleaned_jobs.csv
data/skill_counts.csv

# Jupyter Notebook temporary files
.ipynb_checkpoints/

# Environment variable files
.env